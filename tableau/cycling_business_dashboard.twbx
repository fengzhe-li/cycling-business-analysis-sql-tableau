    <worksheet name='Sheet 20'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='12'>Customer Retention vs Purchase Frequency</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='customer_summary' name='federated.0y7b17r0dseiri12swizr15qld8v' />
          </datasources>
          <datasource-dependencies datasource='federated.0y7b17r0dseiri12swizr15qld8v'>
            <column caption='Customer Lifespan' datatype='integer' name='[Calculation_1281544397746181]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[first_order],[last_order])' />
            </column>
            <column caption='Customer Id' datatype='integer' name='[customer_id]' role='dimension' type='ordinal' />
            <column caption='First Order' datatype='date' name='[first_order]' role='dimension' type='ordinal' />
            <column caption='Last Order' datatype='date' name='[last_order]' role='dimension' type='ordinal' />
            <column-instance column='[customer_id]' derivation='None' name='[none:customer_id:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_1281544397746181]' derivation='Sum' name='[sum:Calculation_1281544397746181:qk]' pivot='key' type='quantitative' />
            <column-instance column='[total_orders]' derivation='Sum' name='[sum:total_orders:qk]' pivot='key' type='quantitative' />
